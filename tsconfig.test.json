{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./.test-dist",
    "noEmit": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false
  },
  "include": [
    "src/access-control.ts",
    "src/config.ts",
    "src/inbound-context.ts",
    "src/outbound.ts",
    "src/persistence.ts",
    "src/message/notice-normalizer.ts",
    "test/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    ".test-dist"
  ]
}
